FROM golang:1.25-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git protoc protobuf-dev

# Install protoc-gen-go and protoc-gen-go-grpc
ENV PATH=$PATH:/root/go/bin
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest
RUN cd /tmp && \
    git clone --depth 1 https://github.com/grpc/grpc-go.git grpc-go && \
    cd grpc-go/cmd/protoc-gen-go-grpc && \
    go install . && \
    rm -rf /tmp/grpc-go

# Create service directory structure to match replace directive
RUN mkdir -p calendar-service

# Copy proto files to /app/proto (../proto relative to /app/calendar-service)
COPY proto /app/proto

# Generate Go code from proto files
WORKDIR /app/proto
RUN protoc --go_out=. --go_opt=module=proto \
    --go-grpc_out=. --go-grpc_opt=module=proto \
    *.proto

# Return to /app
WORKDIR /app

# Copy go mod files to service directory
COPY calendar-service/go.mod calendar-service/
WORKDIR /app/calendar-service

# go.sum will be generated by go mod download if it doesn't exist
RUN go mod download

# Copy source code
COPY calendar-service/ .

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o calendar-service ./cmd/server

# Copy binary to /app for final stage
RUN cp calendar-service /app/calendar-service-bin && \
    rm -rf /app/calendar-service && \
    mv /app/calendar-service-bin /app/calendar-service

FROM alpine:latest

RUN apk --no-cache add ca-certificates netcat-openbsd

WORKDIR /root/

COPY --from=builder /app/calendar-service .

EXPOSE 9095

CMD ["./calendar-service"]
