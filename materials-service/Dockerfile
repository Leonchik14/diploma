FROM golang:1.25-alpine AS builder

WORKDIR /app

# Install dependencies
RUN apk add --no-cache git protoc protobuf-dev

# Install protoc-gen-go and protoc-gen-go-grpc
ENV PATH=$PATH:/root/go/bin
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest
RUN cd /tmp && \
    git clone --depth 1 https://github.com/grpc/grpc-go.git grpc-go && \
    cd grpc-go/cmd/protoc-gen-go-grpc && \
    go install . && \
    rm -rf /tmp/grpc-go

# Create service directory structure to match replace directive
RUN mkdir -p materials-service

# Copy proto files to /app/proto (../proto relative to /app/materials-service)
COPY proto /app/proto

# Generate Go code from proto files
WORKDIR /app/proto
RUN protoc --go_out=. --go_opt=module=proto \
    --go-grpc_out=. --go-grpc_opt=module=proto \
    *.proto

# Return to /app
WORKDIR /app

# Copy go mod files to service directory
COPY materials-service/go.mod materials-service/
WORKDIR /app/materials-service

# go.sum will be generated by go mod download if it doesn't exist
RUN go mod download

# Copy source code
COPY materials-service/ .

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o materials-service ./cmd/materials-service

# Copy binary to /app for final stage
RUN cp materials-service /app/materials-service-bin && \
    rm -rf /app/materials-service && \
    mv /app/materials-service-bin /app/materials-service

# Final stage
FROM alpine:latest

RUN apk --no-cache add ca-certificates netcat-openbsd

WORKDIR /app

# Copy binary from builder
COPY --from=builder /app/materials-service .

# Copy migrations
COPY materials-service/migrations ./migrations

EXPOSE 8081

CMD ["./materials-service"]
