FROM golang:1.24 AS builder

WORKDIR /app

RUN apt-get update && apt-get install -y \
    git \
    protobuf-compiler \
    libprotobuf-dev \
    libmupdf-dev \
    gcc \
    g++ \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Install protoc-gen-go and protoc-gen-go-grpc
ENV PATH=$PATH:/root/go/bin
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest
RUN cd /tmp && \
    git clone --depth 1 https://github.com/grpc/grpc-go.git grpc-go && \
    cd grpc-go/cmd/protoc-gen-go-grpc && \
    go install . && \
    rm -rf /tmp/grpc-go

# Create service directory structure to match replace directive
RUN mkdir -p career-coach-service

# Copy proto files to /app/proto (../proto relative to /app/career-coach-service)
COPY proto /app/proto

# Generate Go code from proto files
WORKDIR /app/proto
RUN protoc --go_out=. --go_opt=module=proto \
    --go-grpc_out=. --go-grpc_opt=module=proto \
    *.proto

# Return to /app
WORKDIR /app

# Copy go mod files to service directory
COPY career-coach-service/go.mod career-coach-service/
WORKDIR /app/career-coach-service

# go.sum will be generated by go mod download if it doesn't exist
RUN go mod download

# Copy source code
COPY career-coach-service/ .

# Update go.sum for all required modules (e.g. pressly/goose)
RUN go mod tidy

RUN CGO_ENABLED=1 GOOS=linux go build -a -ldflags '-extldflags "-static"' -o career-coach-service ./cmd/server

# Final stage: binary + migrations
RUN mkdir -p /app/release && cp career-coach-service /app/release/ && cp -r migrations /app/release/

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    netcat-openbsd \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=builder /app/release/ .

EXPOSE 8082

CMD ["./career-coach-service"]
