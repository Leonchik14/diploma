FROM golang:1.25-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git protoc protobuf-dev

# Install protoc-gen-go and protoc-gen-go-grpc
ENV PATH=$PATH:/root/go/bin
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest
RUN cd /tmp && \
    git clone --depth 1 https://github.com/grpc/grpc-go.git grpc-go && \
    cd grpc-go/cmd/protoc-gen-go-grpc && \
    go install . && \
    rm -rf /tmp/grpc-go

# Create service directory structure to match replace directive
RUN mkdir -p user-service

# Copy proto files to /app/proto (../proto relative to /app/user-service)
COPY proto /app/proto

# Generate Go code from proto files
WORKDIR /app/proto
RUN protoc --go_out=. --go_opt=module=proto \
    --go-grpc_out=. --go-grpc_opt=module=proto \
    *.proto

# Return to /app
WORKDIR /app

# Copy go mod files to service directory
COPY user-service/go.mod user-service/
WORKDIR /app/user-service

# go.sum will be generated by go mod download if it doesn't exist
RUN go mod download

# Copy source code
COPY user-service/ .

# Update go.sum for all required modules (e.g. pressly/goose)
RUN go mod tidy

# Build the application
RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o user-service ./cmd/user-service

# Final stage: binary + migrations
RUN mkdir -p /app/release && cp user-service /app/release/ && cp -r migrations /app/release/

FROM alpine:latest

RUN apk --no-cache add ca-certificates curl netcat-openbsd

WORKDIR /app

COPY --from=builder /app/release/ .

EXPOSE 8080

CMD ["./user-service"]
