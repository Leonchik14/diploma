# Скопируйте в .env и заполните. Не коммитьте .env в git.

# База данных (для docker-compose и локального запуска)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-only-change-in-production
POSTGRES_DB=diploma
DATABASE_URL=postgres://postgres:dev-only-change-in-production@postgres:5432/diploma?sslmode=disable
DB_DSN=postgres://postgres:dev-only-change-in-production@postgres:5432/diploma?sslmode=disable

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=dev-only-change-in-production
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Внутренний ключ между сервисами (сгенерируйте случайную строку)
INTERNAL_API_KEY=dev-internal-key-change-in-production

# JWT: публичный/приватный ключи (сгенерируйте: scripts/generate-keys.sh)
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=

# API Gateway (если ключи в файлах — укажите пути)
# JWT_PUBLIC_KEY_PATH=./jwt_public.pem
# JWT_PRIVATE_KEY_PATH=./jwt_private.pem

# nginx gRPC over TLS: см. HTTPS.md (certbot + копирование PEM в каталог на хосте).
# TLS_DOMAIN=grpc.example.com
# NGINX_TLS_CERT_DIR=/var/lib/diploma/nginx-certs
# NGINX_GRPC_HTTPS_PORT=443
# Для scripts/letsencrypt-deploy-hook.sh после renew (абсолютный путь к корню репозитория):
# COMPOSE_PROJECT_DIR=/path/to/Diploma

# User service — JWT и SMTP
JWT_SECRET=dev-jwt-secret-change-in-production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Interview Prep App
SMTP_TLS=true

# Career Coach — OpenRouter
OPENROUTER_API_KEY=

# Job service — HeadHunter (токен из кабинета HH или OAuth)
HH_APP_TOKEN=
HH_USER_AGENT=InterviewPrepApp/1.0 (your-email@example.com)
