FROM golang:1.24-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git protoc protobuf-dev

# Install protoc-gen-go and protoc-gen-go-grpc
ENV PATH=$PATH:/root/go/bin
RUN go install google.golang.org/protobuf/cmd/protoc-gen-go@latest
RUN cd /tmp && \
    git clone --depth 1 https://github.com/grpc/grpc-go.git grpc-go && \
    cd grpc-go/cmd/protoc-gen-go-grpc && \
    go install . && \
    rm -rf /tmp/grpc-go

# Create service directory structure to match replace directive
RUN mkdir -p job-service

# Copy proto files to /app/proto (../proto relative to /app/job-service)
COPY proto /app/proto

# Generate Go code from proto files
WORKDIR /app/proto
RUN protoc --go_out=. --go_opt=module=proto \
    --go-grpc_out=. --go-grpc_opt=module=proto \
    *.proto

# Return to /app
WORKDIR /app

# Copy go mod files to service directory
COPY job-service/go.mod job-service/
WORKDIR /app/job-service

# go.sum will be generated by go mod download if it doesn't exist
RUN go mod download

# Copy source code
COPY job-service/ .

# Ensure go.sum is up to date
RUN go mod tidy

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o job-service ./cmd/server

# Copy binary to /app for final stage
RUN cp job-service /app/job-service-bin && \
    rm -rf /app/job-service && \
    mv /app/job-service-bin /app/job-service

FROM alpine:latest

RUN apk --no-cache add ca-certificates curl netcat-openbsd

WORKDIR /app

COPY --from=builder /app/job-service .

EXPOSE 8083

CMD ["./job-service"]
